{
    # Cloud Run handles HTTPS externally
}

:80 {
    encode gzip

    # API requests
    @api path /api/*
    handle @api {
        reverse_proxy https://dnd-backend-yh7tabjahq-uc.a.run.app {
            header_up Host dnd-backend-yh7tabjahq-uc.a.run.app
        }
    }

    # All other requests (frontend)
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}

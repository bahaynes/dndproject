# ----------------------------------------
# Frontend
# ----------------------------------------
# Base URL for API requests (frontend fetches /api/...)
VITE_API_URL=/api

# ----------------------------------------
# Backend
# ----------------------------------------
# Database connection string (SQLite default)
DATABASE_URL=sqlite:///./app.db

# Optional: PostgreSQL example
# DATABASE_URL=postgresql://user:password@db:5432/dnd_westmarches

# ----------------------------------------
# Cloudflare ACME (for Caddy HTTPS)
# ----------------------------------------
# API token with DNS edit rights for your domain
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# ----------------------------------------
# Options: dev or prod
MODE=dev

# ----------------------------------------
# LLM Service (OpenRouter)
# ----------------------------------------
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek/deepseek-chat

# ----------------------------------------
# ComfyUI (Local)
# ----------------------------------------
COMFYUI_URL=http://localhost:8188
COMFYUI_TIMEOUT=300

# ----------------------------------------
# One-Shot Generator
# ----------------------------------------
ONESHOT_OUTPUT_DIR=/app/data/oneshots
ONESHOT_MAX_CONCURRENT=2

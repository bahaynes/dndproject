# =============================================================================
# DnD Westmarches Hub - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Required variables are marked with [REQUIRED]
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# API URL for frontend requests (usually /api for local development)
VITE_API_URL=/api
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Database [REQUIRED]
# -----------------------------------------------------------------------------
# SQLite (development)
DATABASE_URL=sqlite:///./app.db

# PostgreSQL (production example)
# DATABASE_URL=postgresql://user:password@db:5432/dnd_westmarches

# -----------------------------------------------------------------------------
# Discord OAuth [REQUIRED for login]
# -----------------------------------------------------------------------------
# Create an application at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback

# Comma-separated Discord user IDs for admin access
ADMIN_DISCORD_IDS=123456789012345678

# -----------------------------------------------------------------------------
# LLM Service (OpenRouter)
# -----------------------------------------------------------------------------
# API configuration for AI features
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-api-key
LLM_MODEL=deepseek/deepseek-chat

# -----------------------------------------------------------------------------
# ComfyUI (Optional - for image generation)
# -----------------------------------------------------------------------------
COMFYUI_URL=http://localhost:8188
COMFYUI_TIMEOUT=300

# -----------------------------------------------------------------------------
# One-Shot Generator (Optional)
# -----------------------------------------------------------------------------
ONESHOT_OUTPUT_DIR=/app/data/oneshots
ONESHOT_MAX_CONCURRENT=2

# -----------------------------------------------------------------------------
# HTTPS / Cloudflare (Production only)
# -----------------------------------------------------------------------------
# API token with DNS edit rights for your domain (for Caddy ACME)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# -----------------------------------------------------------------------------
# Mode: dev or prod
# -----------------------------------------------------------------------------
MODE=dev

# -----------------------------------------------------------------------------
# GitHub Webhook (Production — auto-deploy on push to main)
# -----------------------------------------------------------------------------
# Generate a strong random secret, e.g.: openssl rand -hex 32
# Set the same value in your GitHub repo → Settings → Webhooks → Secret.
WEBHOOK_SECRET=change-me-use-openssl-rand-hex-32

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        gettext-base \
        git \
        podman \
    && rm -rf /var/lib/apt/lists/*

# Download adnanh/webhook binary
ARG WEBHOOK_VERSION=2.8.1
RUN curl -fsSL \
        "https://github.com/adnanh/webhook/releases/download/${WEBHOOK_VERSION}/webhook-linux-amd64" \
        -o /usr/local/bin/webhook \
    && chmod +x /usr/local/bin/webhook

# Non-root user (deploy.sh refuses to run as root)
RUN useradd -m -u 1000 -s /bin/bash appuser

WORKDIR /repo

EXPOSE 9000

USER appuser

ENTRYPOINT ["/repo/kube/start-webhook.sh"]

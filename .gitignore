MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Svelte / Node
/frontend/node_modules
/frontend/.svelte-kit
/frontend/build
/frontend/dist
/frontend/.pnpm-store

# General
.DS_Store
*.pem

# Env files
.env*
kube/secrets.yaml
!.env.example

# DB files
*.db
*.sqlite3

# Log files
*.log

# Build artifacts
/static
run_app.sh.log

# Virtualenv
/backend/venv/
.venv/

# Temporary verification files
jules-scratch/
/data/

# Session notes (ephemeral, per-conversation)
SESSION.md

# Rendered webhook pod yaml (generated by install-webhook.sh with local paths)
kube/webhook-pod-rendered.yaml

# E2E test artifacts
e2e/node_modules/
e2e/package-lock.json
e2e/test-results/
frontend/test-results/

# Use the same base image as the production Containerfile for consistency
FROM public.ecr.aws/docker/library/python:3.12-slim

# Set the working directory
WORKDIR /app

# Install system dependencies needed for python packages
RUN apt-get update && apt-get install -y \
    build-essential libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv

# Copy project definition files to a location that survives volume mount
COPY pyproject.toml /pyproject.toml

# Pre-install dependencies (will be re-run at startup if volume overwrites .venv)
RUN uv sync --no-cache

# Create non-root user and transfer ownership
RUN useradd -u 1000 -r -s /bin/false -d /app appuser \
    && chown -R appuser:appuser /app

# Add virtual environment to PATH
ENV PATH="/app/.venv/bin:$PATH"

USER appuser

# Expose the port for the backend server
EXPOSE 8000

# The command will be provided by docker-compose.dev.yml to allow for --reload

# Use the same base image as the production Containerfile for consistency
FROM public.ecr.aws/docker/library/python:3.11-slim

# Set the working directory
WORKDIR /app

# Install system dependencies needed for python packages
RUN apt-get update && apt-get install -y \
    build-essential libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv

# Copy project definition files
COPY pyproject.toml .
# COPY uv.lock .

# Install dependencies using uv
RUN uv sync --frozen --no-cache || uv sync --no-cache

# Add virtual environment to PATH
ENV PATH="/app/.venv/bin:$PATH"

# Expose the port for the backend server
EXPOSE 8000

# The command will be provided by docker-compose.dev.yml to allow for --reload
